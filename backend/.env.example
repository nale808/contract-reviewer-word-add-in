# Server
NODE_ENV=development
PORT=5001

# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/redlining

# Anthropic Claude API
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Frontend origin for CORS
FRONTEND_ORIGIN=https://localhost:3000

# Microsoft Authentication (MSAL)
# Azure AD App Registration values
# Get from: https://portal.azure.com → App registrations
MSAL_TENANT_ID=your-tenant-id-here
MSAL_CLIENT_ID=your-client-id-here

# SSL certificates (run: mkcert localhost — then paste paths below)
SSL_CERT_PATH=./localhost.pem
SSL_KEY_PATH=./localhost-key.pem

# Development flags (never set to true in production)
SKIP_AUTH=false
MOCK_AI=false
