{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "api/**/*.ts",
    "backend/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "frontend",
    "backend/dist"
  ]
}
